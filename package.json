{
	"name": "translate",
	"description": "Drop in replacement for Google Cloud Translate API v2 using Workers AI",
	"type": "module",
	"scripts": {
		"fmt": "prettier --check .",
		"fmt:fix": "prettier --write .",
		"lint": "eslint **/*.*ts*",
		"lint:fix": "npm run lint -- --fix",
		"build:types:cf": "wrangler types",
		"postbuild:types:cf": "prettier --write worker-configuration.d.ts",
		"build:static": "tsx staticApi.ts",
		"start": "wrangler dev",
		"publish:static": "tsx apiGateway.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/demosjarco/translate.git"
	},
	"author": "DemosJarco <1209494+demosjarco@users.noreply.github.com>",
	"license": "MIT",
	"private": true,
	"bugs": {
		"url": "https://github.com/demosjarco/translate/issues"
	},
	"homepage": "https://github.com/demosjarco/translate#readme",
	"prettier": "@demosjarco/prettier-config",
	"dependencies": {
		"@hono/zod-openapi": "1.5.1",
		"ai": "7.0.35",
		"ai-gateway-provider": "4.0.0",
		"franc-all": "7.2.0",
		"he": "1.2.0",
		"hono": "4.12.31",
		"iso-639-3": "3.0.1",
		"jsonrepair": "3.15.0",
		"validator": "13.15.35",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@demosjarco/prettier-config": "1.0.2",
		"@eslint/js": "10.0.1",
		"@microsoft/eslint-formatter-sarif": "3.1.0",
		"@scalar/openapi-to-markdown": "0.5.36",
		"@types/he": "1.2.3",
		"@types/node": "26.1.1",
		"@types/validator": "13.15.10",
		"cloudflare": "7.0.0",
		"eslint": "10.7.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-zod": "4.8.0",
		"eslint-plugin-zod-mini": "1.5.0",
		"prettier": "3.9.6",
		"tsx": "4.23.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.65.0",
		"wrangler": "4.113.0"
	}
}
